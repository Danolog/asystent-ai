# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require

# Auth (better-auth)
BETTER_AUTH_SECRET=generate-a-random-32-char-string-here
BETTER_AUTH_URL=http://localhost:3000

# Vercel Blob (file storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# Web Push (VAPID — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BPxr...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@example.com

# Google OAuth (Calendar, Docs integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=generate-a-random-string-here
TELEGRAM_BOT_USERNAME=YourBotUsername

# Cron secret (Vercel Cron authorization)
CRON_SECRET=generate-a-random-string-here
